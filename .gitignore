# ── Android / Gradle build outputs ──────────────────────────────────────
.gradle/
build/
*/build/
**/build/
.cxx/
.externalNativeBuild/
captures/
*.apk
*.aab
*.ap_
*.dex
*.hprof
*.jks
*.keystore

# Local SDK path — generated by Android Studio, must NEVER be tracked.
local.properties

# ── IDE state (IntelliJ / Android Studio) ───────────────────────────────
# Shared IDE config under .idea/ is intentionally tracked (code style,
# project system, run configs).  Everything machine-local is ignored.
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/shelf
.idea/dictionaries
.idea/dataSources/
.idea/dataSources.ids
.idea/dataSources.local.xml
.idea/dataSources.xml
.idea/dbnavigator.xml
.idea/httpRequests
.idea/caches/
.idea/deploymentTargetSelector.xml
.idea/deploymentTargetDropDown.xml
.idea/assetWizardSettings.xml
.idea/.name
.idea/misc.xml
.idea/sonarlint/

# Kotlin compiler scratch
.kotlin/

# ── OS / editor cruft ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ── Logs / temp / one-off captures ──────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
*.rej
logcat*.txt
crash-*.txt
issues_data.txt

# ── Secrets ─────────────────────────────────────────────────────────────
# Belt-and-braces: nothing under src should ever contain a real secret,
# but ignore the common filenames anyway so a careless `git add .` is safe.
secrets.properties
api_keys.properties
.env
.env.*
*.pem
*.p12
