<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto Backup + device-transfer policy for Jarvis.

    WHAT SYNCS
      The Room database (jarvis.db) — memory facts, wiki pages, saved
      routines, conversation summaries, reminders, speaker profiles,
      etc. Plus the non-encrypted SharedPreferences stores used by
      the presence / learning layer.

    WHAT DOES NOT
      EncryptedSharedPreferences (jarvis_settings.xml) holds API keys,
      OAuth refresh tokens, and the master-key-encrypted payloads. The
      AES master key lives in the Android KeyStore which is per-device
      and does NOT survive backup or device transfer — restoring an
      encrypted prefs file with a different master key silently produces
      unreadable data. Simpler to re-enter keys on a new device than to
      debug corrupted auth.

      Anything under files/ (TFLite models, recordings, image outputs)
      is excluded — it's either re-downloadable or regenerated locally.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Room database: memory, knowledge, routines, expectations. -->
        <include domain="database" path="jarvis.db" />
        <include domain="database" path="jarvis.db-wal" />
        <include domain="database" path="jarvis.db-shm" />

        <!-- Non-encrypted SharedPreferences the presence + learning layer use. -->
        <include domain="sharedpref" path="jarvis_known_ssids.xml" />
        <include domain="sharedpref" path="jarvis_action_ledger.xml" />
        <include domain="sharedpref" path="jarvis_conversation_threads.xml" />
        <include domain="sharedpref" path="jarvis_routine_synth.xml" />

        <!-- Hard excludes so a future pref file isn't accidentally captured. -->
        <exclude domain="sharedpref" path="jarvis_settings.xml" />
        <exclude domain="file" />
        <exclude domain="external" />
    </cloud-backup>

    <device-transfer>
        <include domain="database" path="jarvis.db" />
        <include domain="database" path="jarvis.db-wal" />
        <include domain="database" path="jarvis.db-shm" />
        <include domain="sharedpref" path="jarvis_known_ssids.xml" />
        <include domain="sharedpref" path="jarvis_action_ledger.xml" />
        <include domain="sharedpref" path="jarvis_conversation_threads.xml" />
        <include domain="sharedpref" path="jarvis_routine_synth.xml" />
        <exclude domain="sharedpref" path="jarvis_settings.xml" />
        <exclude domain="file" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
